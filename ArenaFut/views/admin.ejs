<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>

  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: "Comic Sans MS", "Poppins", sans-serif;
      background: linear-gradient(135deg, #ffd6e7, #ffc0cb, #ffb6c1);
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .container {
      background: #fff0f6;
      padding: 40px;
      border-radius: 20px;
      text-align: center;
      box-shadow: 0 8px 20px rgba(255, 105, 180, 0.3);
      border: 3px solid #ff9ecb;
    }

    h1 {
      color: #ff4da6;
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    p {
      color: #d63384;
      font-size: 1.2rem;
    }

    .container::before {
      content: "🌸 💗 🌸";
      display: block;
      font-size: 1.5rem;
      margin-bottom: 10px;
    }

    .container::after {
      content: "💗 🌸 💗";
      display: block;
      font-size: 1.5rem;
      margin-top: 10px;
    }
  </style>

</head>

<body>

  <div class="container">
    <h1><%= title %></h1>
    <p>Welcome to <%= title %></p>
  </div>

</body>
</html>